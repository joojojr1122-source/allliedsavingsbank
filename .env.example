SESSION_SECRET=replace-with-a-long-random-secret
KV_REST_API_URL=https://your-upstash-redis-url
KV_REST_API_TOKEN=your-upstash-rest-token
# Vercel/Upstash may also provide these names automatically:
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
BANK_DATABASE_KEY=bank-portal-database
ADMIN_PASSWORD=replace-with-admin-password

# Brevo SMTP. Without these, approval emails are generated into the local
# emailOutbox in the JSON database for review.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-login-email
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=your-verified-brevo-sender@your-domain.com
SMTP_FROM_NAME=Allied Savings Operations
