{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/styles.css",
      "dest": "/frontend/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/frontend/app.js"
    },
    {
      "src": "/dashboard(?:\\.html)?",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "/login(?:\\.html)?",
      "dest": "/frontend/login.html"
    },
    {
      "src": "/signup(?:\\.html)?",
      "dest": "/frontend/signup.html"
    },
    {
      "src": "/loading(?:\\.html)?",
      "dest": "/frontend/loading.html"
    },
    {
      "src": "/confirmation(?:\\.html)?",
      "dest": "/frontend/confirmation.html"
    },
    {
      "src": "/admin(?:\\.html)?",
      "dest": "/frontend/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
